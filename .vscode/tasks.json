{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C++ Build (CMake)",
      "type": "shell",
      "command": "cmake --build build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "C++ Configure (CMake)",
      "type": "shell",
      "command": "cmake -B build -DCMAKE_BUILD_TYPE=Debug"
    },
    {
      "label": "Run single file (g++)",
      "type": "shell",
      "command": "g++ -std=c++20 -Wall -Wextra -g '${file}' -o '${fileDirname}/${fileBasenameNoExtension}' && '${fileDirname}/${fileBasenameNoExtension}'",
      "group": "test"
    }
  ]
}
