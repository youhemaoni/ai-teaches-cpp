{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C++ Build (CMake)",
            "type": "shell",
            "command": "cmake --build build",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "C++ Configure (CMake)",
            "type": "shell",
            "command": "cmake -B build -DCMAKE_BUILD_TYPE=Debug"
        },
        {
            "label": "Run single file (g++)",
            "type": "shell",
            "command": "mkdir -p '${workspaceFolder}/build/single' && g++ -std=c++20 -Wall -Wextra -g '${file}' -o '${workspaceFolder}/build/single/${fileBasenameNoExtension}' && '${workspaceFolder}/build/single/${fileBasenameNoExtension}'",
            "group": "test"
        },
        {
            "label": "Build single file for debug (g++)",
            "type": "shell",
            "command": "mkdir -p '${workspaceFolder}/build/single' && g++ -std=c++20 -Wall -Wextra -g '${file}' -o '${workspaceFolder}/build/single/${fileBasenameNoExtension}'",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++ 生成活动文件",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-std=c++20",
                "-g",
                "${file}",
                "-o",
                "${workspaceFolder}/build/single/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "编译当前 .cpp 到 build/single/。"
        }
    ]
}
