{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C++ Build (CMake)",
            "type": "shell",
            "command": "cmake --build build",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "C++ Configure (CMake)",
            "type": "shell",
            "command": "cmake -B build -DCMAKE_BUILD_TYPE=Debug"
        },
        {
            "label": "Run single file (g++)",
            "type": "shell",
            "command": "New-Item -ItemType Directory -Force -Path '${workspaceFolder}/build/single' | Out-Null; D:/soft/mingw64/bin/g++.exe -std=c++20 -Wall -Wextra -g -static '${file}' -o '${workspaceFolder}/build/single/${fileBasenameNoExtension}.exe'; & '${workspaceFolder}/build/single/${fileBasenameNoExtension}.exe'",
            "group": "test"
        },
        {
            "label": "Build single file for debug (g++)",
            "type": "shell",
            "command": "New-Item -ItemType Directory -Force -Path '${workspaceFolder}/build/single' | Out-Null; D:/soft/mingw64/bin/g++.exe -std=c++20 -Wall -Wextra -g -static '${file}' -o '${workspaceFolder}/build/single/${fileBasenameNoExtension}.exe'",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "C/C++: g++ 生成活动文件 (Shell)",
            "type": "shell",
            "command": "New-Item -ItemType Directory -Force -Path '${workspaceFolder}/build/single' | Out-Null; D:/soft/mingw64/bin/g++.exe -fdiagnostics-color=always -std=c++20 -g -static '${file}' -o '${workspaceFolder}/build/single/${fileBasenameNoExtension}.exe'",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "编译当前 .cpp 到 build/single/。"
        }
    ]
}