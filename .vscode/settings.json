{
    "code-runner.runInTerminal": true,
    "code-runner.saveFileBeforeRun": true,
    "code-runner.clearPreviousOutput": true,
    "code-runner.executorMap": {
        "cpp": "cd $dir && mkdir -p $workspaceRoot/build/single && g++ -std=c++20 -Wall -Wextra -g $fileName -o $workspaceRoot/build/single/$fileNameWithoutExt && $workspaceRoot/build/single/$fileNameWithoutExt"
    }
}
