{
    // ── Code Runner 配置 ──
    "code-runner.runInTerminal": true, // 在终端运行（而非输出面板），支持输入
    "code-runner.saveFileBeforeRun": true, // 运行前自动保存文件
    "code-runner.clearPreviousOutput": true, // 每次运行清除上次输出
    "code-runner.executorMap": {
        // PowerShell 语法：用 ; 分隔命令，New-Item -Force 创建目录
        "cpp": "New-Item -ItemType Directory -Force -Path $workspaceRoot/build/single | Out-Null; D:/soft/mingw64/bin/g++.exe -std=c++20 -Wall -Wextra -g -static $dir/$fileName -o $workspaceRoot/build/single/$fileNameWithoutExt.exe; chcp 65001 > $null; & $workspaceRoot/build/single/$fileNameWithoutExt.exe"
    },
    // ── 编辑器配置 ──
    "editor.formatOnSave": true, // 保存时自动格式化
    "files.encoding": "utf8", // 文件编码 UTF-8
    // ── C/C++ 扩展配置 ──
    "C_Cpp.default.cppStandard": "c++20", // C++ 标准设为 C++20
    "C_Cpp.default.compilerPath": "D:/soft/mingw64/bin/g++.exe" // 编译器路径（MinGW-w64 GCC 14.2.0）
}